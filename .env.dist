MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async
INBOUND_EMAIL_DOMAIN=inbound.toastit.local
INBOUND_EMAIL_SECRET=toastit-local-inbound-secret

DEFAULT_URI=http://toastit.test
APP_PORT=80
SERVER_NAME=:80
PUBLIC_API_HOST=api.toastit.test
PUBLIC_API_HOST_PATTERN=^api\.toastit\.test$
MCP_HTTP_PORT=3001
MCP_TOASTIT_PAT=
RECAPTCHA_SITE_KEY=
