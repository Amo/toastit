APP_ENV=dev
APP_SECRET=change-me-local
DATABASE_URL="mysql://app:!ChangeMe!@database:3306/app?serverVersion=11.4.10-MariaDB&charset=utf8mb4"
MAILER_DSN=smtp://mailer:1025
MAILER_FROM=no-reply@toastit.local
XAI_API_KEY=
XAI_BASE_URL="https://api.x.ai/v1"
XAI_MODEL="grok-4-1-fast-reasoning"
XAI_ADVANCED_MODEL="grok-4.20-reasoning"
