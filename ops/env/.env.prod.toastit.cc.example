# Deployment target used by make deploy-prod
DEPLOY_HOST=<host>
DEPLOY_PORT=<port>
DEPLOY_USER=<user>
DEPLOY_DIR=<path>
DEPLOY_ENV_FILE=.env.prod.toastit.cc
DEPLOY_INSTANCE_NAME=toastit-prod
DEPLOY_GHCR_USER=<ghcr_user>

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me
DEFAULT_URI=https://toastit.cc

APP_BIND_PORT=8084

MARIADB_VERSION=11.4
MARIADB_DATABASE=toastit
MARIADB_USER=toastit
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root
DATABASE_URL="mysql://toastit:change-me@database:3306/toastit?serverVersion=11.4.10-MariaDB&charset=utf8mb4"

MAILER_DSN=smtp://user:password@smtp.example.com:587?encryption=tls&auth_mode=login
MAILER_FROM=no-reply@toastit.cc
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async

INBOUND_EMAIL_DOMAIN=inbound.toastit.cc
INBOUND_EMAIL_SECRET=change-me-inbound-secret
INBOUND_SMTP_BIND_PORT=2525
INBOUND_SMTP_MAX_RECIPIENTS_PER_MESSAGE=1
INBOUND_SMTP_MAX_MESSAGES_PER_MINUTE=10
INBOUND_SMTP_RATE_WINDOW_SECONDS=60

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning
XAI_TIMEOUT_SECONDS=45

RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_MIN_SCORE=0.5
GOOGLE_APPLICATION_CREDENTIALS=/run/creds/recaptcha-enterprise-sa.json
