TOASTIT_DIR=/home/debian/toastit
TOASTIT_COMPOSE_FILE=ops/docker-compose.prod.yml
TOASTIT_ENV_FILE=ops/env/.env.prod.toastit.cc
TOASTIT_PROJECT=toastit-prod

BACKUP_LOCAL_DIR=/var/backups/toastit
BACKUP_LOCK_FILE=/var/lock/toastit-backup.lock
LOCAL_RETENTION_DAYS=14
GCS_BUCKET=toastit-prod-backups
GCS_PREFIX=db
GCP_PROJECT=your-gcp-project-id
# Host path used by gcloud (not the in-container /run/creds path).
# Reuses the existing creds file already referenced by ops/docker-compose.prod.yml.
GOOGLE_APPLICATION_CREDENTIALS=/home/debian/toastit/ops/creds/recaptcha-enterprise-sa.json

DIGEST_LOCK_FILE=/var/lock/toastit-digest.lock
DIGEST_DATE=yesterday
