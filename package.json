{
  "name": "toastit",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:css": "sass --no-source-map --style=compressed assets/styles/app.scss public/styles/app.css",
    "dev": "vite build --watch --mode development",
    "dev:assets": "concurrently \"npm:watch:css\" \"npm:dev\"",
    "watch:css": "sass --watch --no-source-map assets/styles/app.scss public/styles/app.css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bulma": "^1.0.4",
    "dompurify": "^3.3.3",
    "flowbite": "^4.0.1",
    "flowbite-vue": "^0.2.3",
    "markdown-it": "^14.1.1",
    "sass": "^1.98.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
