{% extends 'app/layout.html.twig' %}

{% block title %}Toastit App{% endblock %}

{% set app_section = 'workspace' %}

{% block app_content %}
    <div class="toastit-stack toastit-page-stack" x-data="{ teamModalOpen: false, adHocMeetingModalOpen: false }">
        {% include 'components/ui/_section_heading.html.twig' with {
            eyebrow: 'Workspace',
            title_tag: 'h1',
            title: 'Vos equipes et meetings.',
            lead: 'Premier noyau metier de Toastit: creer une equipe, planifier un meeting, ajouter des sujets et voter.'
        } only %}

        <div class="buttons">
            {% include 'components/ui/_button.html.twig' with {
                variant: 'primary',
                label: 'Creer une equipe',
                extra_attrs: '@click="teamModalOpen = true"'
            } only %}
            {% include 'components/ui/_button.html.twig' with {
                variant: 'secondary',
                label: 'Creer un meeting ad-hoc',
                extra_attrs: '@click="adHocMeetingModalOpen = true"'
            } only %}
            <a class="button toastit-button-secondary" href="{{ path('app_design_system') }}">Retour au design system</a>
        </div>

            {% for message in app.flashes('error') %}
                {% include 'components/ui/_alert.html.twig' with { tone: 'error', message: message } only %}
            {% endfor %}

        {% embed 'components/ui/_panel.html.twig' %}
            {% block panel_content %}
                <h2 class="title is-5">Meetings par equipe</h2>
                {% if teams is empty %}
                    <p class="toastit-lead">Aucune equipe pour l'instant.</p>
                {% else %}
                    <div class="toastit-table-wrap">
                        <table class="table is-fullwidth toastit-table toastit-table--grouped">
                            <thead>
                                <tr>
                                    <th>Equipe / Meeting</th>
                                    <th>Date</th>
                                    <th>Visio</th>
                                    <th>Recurrence</th>
                                    <th class="has-text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for team in teams %}
                                    <tr class="toastit-table__group-row">
                                        <td colspan="5">
                                            <div class="toastit-table__group-head">
                                                <div>
                                                    <p class="toastit-table__title">{{ team.name }}</p>
                                                    <p class="toastit-table__meta">{{ team.meetings|length }} meeting{% if team.meetings|length > 1 %}s{% endif %} · {{ team.items|length }} sujet{% if team.items|length > 1 %}s{% endif %}</p>
                                                </div>
                                                <a class="button toastit-button-secondary" href="{{ path('app_team_show', { id: team.id }) }}">Equipe</a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% if team.meetings is empty %}
                                        <tr class="toastit-table__nested-row">
                                            <td colspan="5" class="toastit-table__empty">Aucun meeting pour cette equipe.</td>
                                        </tr>
                                    {% else %}
                                        {% for meeting in team.meetings %}
                                            <tr class="toastit-table__nested-row">
                                                <td>
                                                    <div class="toastit-table__nested-content">
                                                        <p class="toastit-table__title">{{ meeting.title }}</p>
                                                    </div>
                                                </td>
                                                <td class="toastit-table__date">{{ meeting.scheduledAt|date('d/m/Y H:i') }}</td>
                                                <td class="toastit-table__date">{{ meeting.videoLink ?: '—' }}</td>
                                                <td>
                                                    {% if meeting.isRecurring %}
                                                        <span class="tag toastit-button-secondary">{{ meeting.recurrence ?: 'recurrent' }}</span>
                                                    {% else %}
                                                        <span class="tag is-light">One-shot</span>
                                                    {% endif %}
                                                </td>
                                                <td class="has-text-right">
                                                    <a class="button is-primary" href="{{ path('app_meeting_show', { id: meeting.id }) }}">Ouvrir</a>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% endblock %}
        {% endembed %}

        {% embed 'components/ui/_panel.html.twig' %}
            {% block panel_content %}
                <h2 class="title is-5">Meetings ad-hoc</h2>
                {% if ad_hoc_meetings is empty %}
                    <p class="toastit-lead">Aucun meeting ad-hoc pour l'instant.</p>
                {% else %}
                    <div class="toastit-table-wrap">
                        <table class="table is-fullwidth toastit-table">
                            <thead>
                                <tr>
                                    <th>Titre</th>
                                    <th>Date</th>
                                    <th>Visio</th>
                                    <th>Recurrence</th>
                                    <th class="has-text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for meeting in ad_hoc_meetings %}
                                    <tr>
                                        <td>
                                            <p class="toastit-table__title">{{ meeting.title }}</p>
                                        </td>
                                        <td class="toastit-table__date">{{ meeting.scheduledAt|date('d/m/Y H:i') }}</td>
                                        <td class="toastit-table__date">{{ meeting.videoLink ?: '—' }}</td>
                                        <td>
                                            {% if meeting.isRecurring %}
                                                <span class="tag toastit-button-secondary">{{ meeting.recurrence ?: 'recurrent' }}</span>
                                            {% else %}
                                                <span class="tag is-light">One-shot</span>
                                            {% endif %}
                                        </td>
                                        <td class="has-text-right">
                                            <a class="button is-primary" href="{{ path('app_meeting_show', { id: meeting.id }) }}">Ouvrir</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% endblock %}
        {% endembed %}

        <div class="toastit-focus-backdrop" x-cloak x-show="teamModalOpen" x-transition.opacity @click="teamModalOpen = false"></div>
        <div class="toastit-focus-modal" x-cloak x-show="teamModalOpen" x-transition.scale.origin.center>
            <div class="toastit-focus-modal__card">
                <div class="toastit-sheet__header">
                    <div>
                        <h2 class="title is-5 mb-2">Creer une equipe</h2>
                        <p class="toastit-sheet__description">Ajoutez un nom d'equipe pour ouvrir un premier espace de travail partage.</p>
                    </div>
                    <button class="toastit-icon-close" type="button" aria-label="Close team modal" @click="teamModalOpen = false">
                        {% include 'components/ui/_icon.html.twig' with { name: 'xmark' } only %}
                    </button>
                </div>
                <form method="post" class="toastit-stack">
                    <div class="field">
                        <label class="label" for="team-name">Nom de l'equipe</label>
                        <div class="control">
                            <input id="team-name" class="input toastit-input" name="name" type="text" required>
                        </div>
                    </div>
                    <div class="buttons mb-0">
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'primary',
                            type: 'submit',
                            label: "Creer l'equipe"
                        } only %}
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'notice',
                            type: 'button',
                            label: 'Annuler',
                            extra_attrs: '@click="teamModalOpen = false"'
                        } only %}
                    </div>
                </form>
            </div>
        </div>

        <div class="toastit-focus-backdrop" x-cloak x-show="adHocMeetingModalOpen" x-transition.opacity @click="adHocMeetingModalOpen = false"></div>
        <div class="toastit-focus-modal" x-cloak x-show="adHocMeetingModalOpen" x-transition.scale.origin.center>
            <div class="toastit-focus-modal__card">
                <div class="toastit-sheet__header">
                    <div>
                        <h2 class="title is-5 mb-2">Creer un meeting ad-hoc</h2>
                        <p class="toastit-sheet__description">Planifiez un meeting personnel ou one-to-one sans le rattacher a une equipe.</p>
                    </div>
                    <button class="toastit-icon-close" type="button" aria-label="Close ad hoc meeting modal" @click="adHocMeetingModalOpen = false">
                        {% include 'components/ui/_icon.html.twig' with { name: 'xmark' } only %}
                    </button>
                </div>
                <form method="post" action="{{ path('app_ad_hoc_meeting_create') }}" class="toastit-stack">
                    <div class="field">
                        <label class="label" for="adhoc-title">Titre</label>
                        <div class="control">
                            <input id="adhoc-title" class="input toastit-input" name="title" type="text" required>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label" for="adhoc-date">Date et heure</label>
                        <div class="control">
                            <input id="adhoc-date" class="input toastit-input" name="scheduled_at" type="datetime-local" required>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label" for="adhoc-video">Lien visio</label>
                        <div class="control">
                            <input id="adhoc-video" class="input toastit-input" name="video_link" type="url">
                        </div>
                    </div>
                    <div class="field">
                        <label class="checkbox">
                            <input type="checkbox" name="is_recurring" value="1">
                            Meeting recurrent
                        </label>
                    </div>
                    <div class="toastit-two-columns">
                        <div class="field">
                            <label class="label" for="adhoc-recurrence-quantity">Quantite</label>
                            <div class="control">
                                <input id="adhoc-recurrence-quantity" class="input toastit-input" name="recurrence_quantity" type="number" min="1" value="1">
                            </div>
                        </div>
                        <div class="field">
                            <label class="label" for="adhoc-recurrence-unit">Unite</label>
                            <div class="control">
                                <div class="select is-fullwidth">
                                    <select id="adhoc-recurrence-unit" name="recurrence_unit">
                                        <option value="days">Jours</option>
                                        <option value="week">Semaine</option>
                                        <option value="two_weeks">Deux semaines</option>
                                        <option value="months">Mois</option>
                                        <option value="two_months">Deux mois</option>
                                        <option value="quarter">Trimestre</option>
                                        <option value="semester">Semestre</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="buttons mb-0">
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'primary',
                            type: 'submit',
                            label: 'Creer le meeting'
                        } only %}
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'notice',
                            type: 'button',
                            label: 'Annuler',
                            extra_attrs: '@click="adHocMeetingModalOpen = false"'
                        } only %}
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
