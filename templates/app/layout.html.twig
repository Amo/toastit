{% extends 'base.html.twig' %}

{% set current_section = app_section|default('workspace') %}

{% block body %}
    <div class="toastit-app-shell" x-data="{ userMenuOpen: false }">
        <header class="toastit-app-header">
            <div class="toastit-app-header__inner">
                <div class="toastit-app-brand">
                    <a class="toastit-app-brand__link" href="{{ path('app_dashboard') }}">Toastit</a>
                </div>

                <nav class="toastit-app-nav" aria-label="Navigation principale">
                    <a class="toastit-app-nav__link{% if current_section == 'workspace' %} is-active{% endif %}" href="{{ path('app_dashboard') }}">Workspace</a>
                    <a class="toastit-app-nav__link{% if current_section == 'design' %} is-active{% endif %}" href="{{ path('app_design_system') }}">Design</a>
                </nav>

                <div class="toastit-app-user" @keydown.escape.window="userMenuOpen = false">
                    <button class="toastit-app-user__button" type="button" @click="userMenuOpen = !userMenuOpen" :aria-expanded="userMenuOpen.toString()">
                        {% include 'components/ui/_icon.html.twig' with {
                            name: 'circle-user',
                            container_class: 'toastit-app-user__icon'
                        } only %}
                        <span class="toastit-app-user__label">{{ app.user ? app.user.displayName : 'Compte' }}</span>
                        {% include 'components/ui/_icon.html.twig' with {
                            name: 'chevron-down',
                            container_class: 'toastit-app-user__chevron'
                        } only %}
                    </button>

                    <div class="toastit-app-user__menu" x-cloak x-show="userMenuOpen" x-transition.origin.top.right @click.outside="userMenuOpen = false">
                        <div class="toastit-app-user__menu-meta">
                            <strong>{{ app.user ? app.user.displayName : 'Compte' }}</strong>
                            <span>{{ app.user and 'ROLE_ROOT' in app.user.roles ? 'ROOT user' : 'Utilisateur' }}</span>
                        </div>
                        <a class="toastit-app-user__menu-link" href="{{ path('app_profile') }}">Mon profil</a>
                        <form method="post" action="{{ path('app_logout') }}">
                            {% include 'components/ui/_button.html.twig' with {
                                variant: 'notice',
                                type: 'submit',
                                label: 'Se deconnecter',
                                class: 'is-fullwidth'
                            } only %}
                        </form>
                    </div>
                </div>
            </div>
        </header>

        <main class="toastit-app-content">
            <div class="toastit-app-container">
                {% block app_content %}{% endblock %}
            </div>
        </main>
    </div>
{% endblock %}
