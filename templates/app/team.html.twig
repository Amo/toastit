{% extends 'app/layout.html.twig' %}

{% block title %}{{ team.name }}{% endblock %}

{% set app_section = 'workspace' %}

{% block app_content %}
    <div class="toastit-stack toastit-page-stack" x-data="{ meetingModalOpen: false }">
        {% include 'components/ui/_section_heading.html.twig' with {
            eyebrow: 'Equipe',
            title_tag: 'h1',
            title: team.name,
            lead: 'Parking lot partage, meetings a venir et votes de priorisation.'
        } only %}

        <div class="buttons">
            {% include 'components/ui/_button.html.twig' with {
                variant: 'primary',
                label: 'Creer un meeting',
                extra_attrs: '@click="meetingModalOpen = true"'
            } only %}
            <a class="button toastit-button-secondary" href="{{ path('app_dashboard') }}">Retour au dashboard</a>
        </div>

            {% for message in app.flashes('error') %}
                {% include 'components/ui/_alert.html.twig' with { tone: 'error', message: message } only %}
            {% endfor %}
            {% for message in app.flashes('success') %}
                {% include 'components/ui/_alert.html.twig' with { tone: 'success', message: message } only %}
            {% endfor %}

            {% embed 'components/ui/_panel.html.twig' %}
                {% block panel_content %}
                    <h2 class="title is-5">Membres</h2>
                    <div class="toastit-list">
                        {% for membership in team.memberships %}
                            <article class="toastit-list-item">
                                <div class="toastit-table__author">
                                    <img class="toastit-avatar-image" src="{{ membership.user.gravatarUrl(80) }}" alt="" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-grid';">
                                    <span class="toastit-avatar" style="display:none">{{ membership.user.initials }}</span>
                                    <span>{{ membership.user.displayName }}</span>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                    <form method="post" action="{{ path('app_team_invite', { id: team.id }) }}" class="toastit-stack mt-4">
                        <div class="field has-addons">
                            <div class="control is-expanded">
                                <input class="input toastit-input" name="email" type="email" placeholder="Invite by email" required>
                            </div>
                            <div class="control">
                                {% include 'components/ui/_button.html.twig' with {
                                    variant: 'primary',
                                    type: 'submit',
                                    label: 'Invite'
                                } only %}
                            </div>
                        </div>
                    </form>
                {% endblock %}
            {% endembed %}

            {% embed 'components/ui/_panel.html.twig' %}
                {% block panel_content %}
                    <h2 class="title is-5">Meetings</h2>
                    {% if team.meetings is empty %}
                        <p class="toastit-lead">Aucun meeting pour l'instant.</p>
                    {% else %}
                        <div class="toastit-list">
                            {% for meeting in team.meetings %}
                                <article class="toastit-list-item toastit-list-item--with-action">
                                    <div>
                                        <p class="toastit-list-item__title">{{ meeting.title }}</p>
                                        <p class="toastit-list-item__meta">{{ meeting.scheduledAt|date('d/m/Y H:i') }}{% if meeting.videoLink %} · {{ meeting.videoLink }}{% endif %}</p>
                                    </div>
                                    <div class="buttons mb-0">
                                        {% if meeting.isRecurring %}
                                            <span class="tag toastit-button-secondary">{{ meeting.recurrence ?: 'recurrent' }}</span>
                                        {% endif %}
                                        <a class="button is-primary" href="{{ path('app_meeting_show', { id: meeting.id }) }}">Ouvrir</a>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}

        <div class="toastit-focus-backdrop" x-cloak x-show="meetingModalOpen" x-transition.opacity @click="meetingModalOpen = false"></div>
        <div class="toastit-focus-modal" x-cloak x-show="meetingModalOpen" x-transition.scale.origin.center>
            <div class="toastit-focus-modal__card">
                <div class="toastit-sheet__header">
                    <div>
                        <h2 class="title is-5 mb-2">Creer un meeting</h2>
                        <p class="toastit-sheet__description">Planifiez un meeting one-shot ou recurrent, avec date, lien visio et recurrence structuree.</p>
                    </div>
                    <button class="toastit-icon-close" type="button" aria-label="Close meeting modal" @click="meetingModalOpen = false">
                        {% include 'components/ui/_icon.html.twig' with { name: 'xmark' } only %}
                    </button>
                </div>
                <form method="post" action="{{ path('app_team_meeting_create', { id: team.id }) }}" class="toastit-stack">
                    <div class="field">
                        <label class="label" for="meeting-title">Titre</label>
                        <div class="control">
                            <input id="meeting-title" class="input toastit-input" name="title" type="text" required>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label" for="meeting-date">Date et heure</label>
                        <div class="control">
                            <input id="meeting-date" class="input toastit-input" name="scheduled_at" type="datetime-local" required>
                        </div>
                    </div>
                    <div class="field">
                        <label class="label" for="meeting-video">Lien visio</label>
                        <div class="control">
                            <input id="meeting-video" class="input toastit-input" name="video_link" type="url">
                        </div>
                    </div>
                    <div class="field">
                        <label class="checkbox">
                            <input type="checkbox" name="is_recurring" value="1">
                            Meeting recurrent
                        </label>
                    </div>
                    <div class="toastit-two-columns">
                        <div class="field">
                            <label class="label" for="meeting-recurrence-quantity">Quantite</label>
                            <div class="control">
                                <input id="meeting-recurrence-quantity" class="input toastit-input" name="recurrence_quantity" type="number" min="1" value="1">
                            </div>
                        </div>
                        <div class="field">
                            <label class="label" for="meeting-recurrence-unit">Unite</label>
                            <div class="control">
                                <div class="select is-fullwidth">
                                    <select id="meeting-recurrence-unit" name="recurrence_unit">
                                        <option value="days">Jours</option>
                                        <option value="week">Semaine</option>
                                        <option value="two_weeks">Deux semaines</option>
                                        <option value="months">Mois</option>
                                        <option value="two_months">Deux mois</option>
                                        <option value="quarter">Trimestre</option>
                                        <option value="semester">Semestre</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="buttons mb-0">
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'primary',
                            type: 'submit',
                            label: 'Creer le meeting'
                        } only %}
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'notice',
                            type: 'button',
                            label: 'Annuler',
                            extra_attrs: '@click="meetingModalOpen = false"'
                        } only %}
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
