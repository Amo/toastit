{% extends 'base.html.twig' %}

{% block title %}Verifier votre email{% endblock %}

{% block body %}
    <main class="toastit-shell">
        {% embed 'components/ui/_panel.html.twig' with { class: 'toastit-panel--narrow' } %}
            {% block panel_content %}
                {% include 'components/ui/_section_heading.html.twig' with {
                    eyebrow: 'Verification',
                    title_tag: 'h1',
                    title: 'Entrez le code recu par email.',
                    lead: "Le lien magique de l'email vous connecte directement. Si le bouton ne fonctionne pas, utilisez le code OTP de secours."
                } only %}

                <div class="toastit-stack">
                    {% for message in app.flashes('success') %}
                        {% include 'components/ui/_alert.html.twig' with { tone: 'success', message: message } only %}
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        {% include 'components/ui/_alert.html.twig' with { tone: 'error', message: message } only %}
                    {% endfor %}

                    <form method="post" action="{{ path('app_auth_verify') }}" class="toastit-stack">
                        <input type="hidden" name="email" value="{{ email }}">
                        <input type="hidden" name="purpose" value="{{ purpose }}">
                        {% include 'components/forms/_segmented_code_input.html.twig' with {
                            id: 'otp-code',
                            name: 'code',
                            label: 'Code OTP',
                            length: 6,
                            mode: 'alnum',
                            autocomplete: 'one-time-code',
                            auto_submit: true
                        } only %}
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'primary',
                            type: 'submit',
                            label: 'Verifier le code'
                        } only %}
                    </form>
                </div>
            {% endblock %}
        {% endembed %}
    </main>
{% endblock %}
