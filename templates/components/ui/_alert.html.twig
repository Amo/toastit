{% set tone_map = {
    success: 'is-success',
    error: 'is-danger',
    info: 'is-info',
    warning: 'is-warning',
    notice: 'is-light'
} %}
{% set tone = tone|default('info') %}
{% set classes = ['message', tone_map[tone]|default(tone_map.info), 'is-small'] %}
{% if class is defined and class %}
    {% set classes = classes|merge([class]) %}
{% endif %}

<article class="{{ classes|join(' ')|trim }}">
    <div class="message-body">{{ message }}</div>
</article>
