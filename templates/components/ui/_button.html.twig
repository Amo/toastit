{% set variant_map = {
    primary: 'is-primary',
    secondary: 'toastit-button-secondary',
    success: 'is-success',
    info: 'is-info',
    warning: 'is-warning',
    danger: 'is-danger',
    notice: 'toastit-button-notice',
    arrow: 'toastit-arrow-button'
} %}
{% set variant = variant|default('primary') %}
{% set classes = ['button', variant_map[variant]|default(variant_map.primary)] %}
{% if class is defined and class %}
    {% set classes = classes|merge([class]) %}
{% endif %}

<button
    class="{{ classes|join(' ')|trim }}"
    type="{{ type|default('button') }}"
    {% if aria_label is defined and aria_label %}aria-label="{{ aria_label }}"{% endif %}
    {{ extra_attrs|default('')|raw }}
>
    {% if icon_name is defined and icon_name %}
        {% include 'components/ui/_icon.html.twig' with {
            name: icon_name,
            style: icon_style|default('solid'),
            container_class: icon_only|default(false) ? null : 'icon'
        } only %}
    {% endif %}
    {% if label is defined and label %}
        <span>{{ label }}</span>
    {% endif %}
</button>
