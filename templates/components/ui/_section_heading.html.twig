<div class="toastit-stack{% if class is defined and class %} {{ class }}{% endif %}">
    {% if eyebrow is defined and eyebrow %}
        <p class="toastit-eyebrow">{{ eyebrow }}</p>
    {% endif %}
    {% if title is defined and title %}
        <{{ title_tag|default('h2') }} class="toastit-display">{{ title }}</{{ title_tag|default('h2') }}>
    {% endif %}
    {% if lead is defined and lead %}
        <p class="toastit-lead">{{ lead }}</p>
    {% endif %}
</div>
