                                        <span class="toastit-avatar" x-text="row.initials"></span>
                                        <span x-text="row.author"></span>
                                    </div>
                                </td>
                                <td class="toastit-table__date" x-text="row.date"></td>
                                <td>
                                    <span class="tag is-light toastit-counter" x-text="row.count"></span>
                                </td>
                                <td class="has-text-right">
