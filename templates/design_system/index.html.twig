        <section class="toastit-ds__section">
            <div class="toastit-ds__section-head">
                <h2 class="title is-4">Icon Direction</h2>
                <p class="subtitle is-6">Moodboard fonctionnel avant de choisir une librairie definitive.</p>
            </div>
            <div class="toastit-icon-grid">
                <article class="toastit-icon-card">
                    {% include 'components/ui/_icon.html.twig' with {
                        name: 'arrow-right',
                        container_class: 'toastit-icon-badge'
                    } only %}
                    <strong>Directional</strong>
                    <span>actions, navigation</span>
                </article>
                <article class="toastit-icon-card">
                    {% include 'components/ui/_icon.html.twig' with {
