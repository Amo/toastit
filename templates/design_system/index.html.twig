{% extends 'base.html.twig' %}

{% block title %}Toastit Design System{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js"></script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('toastitTableDemo', () => ({
                search: '',
                rows: [
                    { id: 1, checked: true, title: 'Toast sent to hiring shortlist', author: 'Nina', initials: 'NI', date: '31 Mar 2026', count: 12 },
                    { id: 2, checked: false, title: 'Weekly digest draft for ambassadors', author: 'Leo', initials: 'LE', date: '29 Mar 2026', count: 4 },
                    { id: 3, checked: true, title: 'Referral invite flow copy review', author: 'Maya', initials: 'MA', date: '28 Mar 2026', count: 9 },
                    { id: 4, checked: false, title: 'Founders beta onboarding checklist', author: 'Noah', initials: 'NO', date: '25 Mar 2026', count: 2 }
                ],
                filteredRows() {
                    const query = this.search.trim().toLowerCase();

                    if (!query) {
                        return this.rows;
                    }

                    return this.rows.filter((row) =>
                        row.title.toLowerCase().includes(query)
                        || row.author.toLowerCase().includes(query)
                        || row.date.toLowerCase().includes(query)
                    );
                },
                increment(row) {
                    row.count += 1;
                },
                decrement(row) {
                    row.count = Math.max(0, row.count - 1);
                }
            }));

            Alpine.data('toastitFeedbackDemo', () => ({
                slider: 42,
                focusOpen: false,
                drawerOpen: false,
                sheetOpen: false,
                toasts: [],
                toastId: 0,
                pushToast(tone) {
                    const labels = {
                        success: 'Toast success',
                        info: 'Toast info',
                        warning: 'Toast warning',
                        danger: 'Toast danger',
                        notice: 'Toast notice'
                    };

                    const toast = {
                        id: ++this.toastId,
                        tone,
                        label: labels[tone]
                    };

                    this.toasts.push(toast);

                    setTimeout(() => {
                        this.toasts = this.toasts.filter((item) => item.id !== toast.id);
                    }, 2800);
                }
            }));
        });
    </script>
{% endblock %}

{% block body %}
    <main class="toastit-ds">
