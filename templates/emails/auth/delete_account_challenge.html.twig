{% extends 'emails/base.html.twig' %}

{% block email_body %}
    <h1 style="margin:0 0 16px;font-size:28px;line-height:1.1;">Suppression du compte Toastit</h1>
    <p style="margin:0 0 24px;font-size:16px;line-height:1.6;">
        Une demande de suppression definitive de votre compte a ete lancee. Utilisez le code ci-dessous dans l'application pour confirmer.
    </p>
    <p style="margin:0 0 8px;font-size:14px;color:#6b7280;">Code de confirmation</p>
    <p style="margin:0 0 24px;font-size:32px;font-weight:700;letter-spacing:0.12em;">{{ challenge.code|slice(0, 3) }} {{ challenge.code|slice(3, 3) }}</p>
    <p style="margin:0;font-size:14px;color:#6b7280;">Ce code expire dans 10 minutes et ne peut etre utilise qu'une seule fois.</p>
{% endblock %}
