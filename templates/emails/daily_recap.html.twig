{% extends 'emails/base.html.twig' %}

{% block email_body %}
    <style>
        .toastit-digest h2 { margin: 0 0 14px; font-size: 22px; line-height: 1.3; color: #111827; }
        .toastit-digest h3 { margin: 28px 0 10px; font-size: 17px; line-height: 1.4; color: #b45309; }
        .toastit-digest p { margin: 0 0 12px; }
        .toastit-digest ul { margin: 0 0 16px; padding-left: 22px; }
        .toastit-digest li { margin: 0 0 8px; }
    </style>
    <h1 style="margin:0 0 12px;font-size:30px;line-height:1.15;font-weight:700;color:#111827;">Your daily Toastit digest</h1>
    <p style="margin:0 0 24px;font-size:16px;line-height:1.6;color:#4b5563;">
        Start with today’s actions, then review attention points and yesterday’s signals.
    </p>
    <div class="toastit-digest" style="margin:0;font-size:15px;line-height:1.7;color:#111827;">
        {{ summary_html|raw }}
    </div>
    <hr style="margin:32px 0 20px;border:0;border-top:1px solid #e5e7eb;">
    <p style="margin:0 0 10px;font-size:13px;line-height:1.6;color:#6b7280;">
        Toastit helps teams turn ideas, signals, and requests into visible actions and follow-ups.
    </p>
    <p style="margin:0 0 10px;font-size:13px;line-height:1.6;color:#6b7280;">
        You can delete your account or stop daily or weekly digest emails at any time from your profile settings.
    </p>
    <p style="margin:0;font-size:13px;line-height:1.6;color:#6b7280;">
        Suggestions, feedback, or issues: <a href="mailto:{{ contact_email }}" style="color:#b45309;text-decoration:underline;">{{ contact_email }}</a>
    </p>
{% endblock %}
