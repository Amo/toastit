{% extends 'emails/base.html.twig' %}

{% block email_body %}
    <h1 style="margin:0 0 12px;font-size:24px;line-height:1.2;">Toast actions processed</h1>
    <p style="margin:0 0 12px;font-size:15px;line-height:1.6;">
        <strong>{{ context_label }}</strong>
    </p>
    <p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#374151;">
        Applied: <strong>{{ applied_count }}</strong> · Pending confirmation: <strong>{{ pending_count }}</strong>
    </p>

    <div style="margin:0 0 16px;border:1px solid #eceff3;border-radius:14px;overflow:hidden;">
        {% for result in action_results %}
            <div style="padding:12px 14px;{% if not loop.last %}border-bottom:1px solid #eceff3;{% endif %}">
                <p style="margin:0 0 4px;font-size:13px;line-height:1.4;font-weight:700;letter-spacing:0.03em;text-transform:uppercase;color:
                    {% if result.status == 'applied' %}#047857{% elseif result.status == 'pending_confirmation' %}#b45309{% else %}#b91c1c{% endif %};">
                    {{ result.status|replace({'_': ' '}) }}
                </p>
                <p style="margin:0 0 4px;font-size:14px;line-height:1.5;color:#111827;">
                    #{{ result.taskId }} {{ result.summary }}
                </p>
                <p style="margin:0;font-size:13px;line-height:1.5;color:#4b5563;">
                    {{ result.details }}
                </p>
                {% if result.options is defined and result.options|length > 0 %}
                    <div style="margin-top:8px;font-size:13px;line-height:1.5;">
                        {% for option in result.options %}
                            <div style="margin-top:4px;">
                                <a href="{{ option.url }}" style="color:#b45309;text-decoration:none;font-weight:700;">
                                    {{ option.label }}
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {% if pending_count > 0 %}
        <div style="margin:0;padding:14px;border:1px solid #fde68a;border-radius:14px;background:#fffbeb;font-size:14px;line-height:1.6;color:#92400e;">
            <p style="margin:0 0 6px;font-weight:700;">Some commands need confirmation</p>
            <p style="margin:0;">Reply with explicit commands (one per line), for example:</p>
            <ul style="margin:6px 0 0 18px;padding:0;">
                <li>#123 assign owner@example.com</li>
                <li>#123 due 2026-04-20</li>
                <li>#123 move Product Board</li>
            </ul>
        </div>
    {% endif %}
{% endblock %}
