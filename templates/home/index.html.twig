{% extends 'base.html.twig' %}

{% block title %}Toastit{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script id="toastit-home-payload" type="application/json">{{ payload|json_encode|raw }}</script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('toastitHome', () => JSON.parse(document.getElementById('toastit-home-payload').textContent));
        });
    </script>
{% endblock %}

{% block body %}
    <main class="toastit-shell" x-data="toastitHome()">
        {% embed 'components/ui/_panel.html.twig' with { class: 'toastit-panel--narrow' } %}
            {% block panel_content %}
                {% include 'components/ui/_section_heading.html.twig' with {
                    eyebrow: 'Toastit',
                    title_tag: 'h1',
                    title: 'Une interface mobile-first pour agir vite, sans surcharge.',
                    lead: "Toastit centralise l'essentiel dans une experience legere: le serveur fait le gros du travail, et le front reste net, tactile et immediat."
                } only %}

                <div class="toastit-stack">
                    {% for message in app.flashes('success') %}
                        {% include 'components/ui/_alert.html.twig' with {
                            tone: 'success',
                            message: message
                        } only %}
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        {% include 'components/ui/_alert.html.twig' with {
                            tone: 'error',
                            message: message
                        } only %}
                    {% endfor %}

                    {% if app.user %}
                        {% include 'components/ui/_alert.html.twig' with {
                            tone: 'notice',
                            message: 'Vous etes deja connecte.'
                        } only %}

                        <div class="buttons">
                            <a class="button is-primary" href="{{ path('app_dashboard') }}">Ouvrir l'application</a>
                            <form method="post" action="{{ path('app_logout') }}">
                                {% include 'components/ui/_button.html.twig' with {
                                    variant: 'notice',
                                    type: 'submit',
                                    label: 'Se deconnecter'
                                } only %}
                            </form>
                        </div>
                    {% else %}
                        {% include 'components/forms/_email_login_inline.html.twig' with {
                            action: path('app_login_email'),
                            email: payload.email
                        } only %}
                    {% endif %}
                </div>
            {% endblock %}
        {% endembed %}
    </main>
{% endblock %}
