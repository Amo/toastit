{% extends 'base.html.twig' %}

{% block title %}Deverrouiller{% endblock %}

{% block body %}
    <main class="toastit-shell">
        {% embed 'components/ui/_panel.html.twig' %}
            {% block panel_content %}
                {% include 'components/ui/_section_heading.html.twig' with {
                    eyebrow: 'Deverrouillage',
                    title_tag: 'h1',
                    title: 'Entrez votre PIN.',
                    lead: "La session est authentifiee pour " ~ email ~ ", mais le PIN est requis pour acceder a l'application."
                } only %}

                <div class="toastit-stack">
                    {% for message in app.flashes('success') %}
                        {% include 'components/ui/_alert.html.twig' with { tone: 'success', message: message } only %}
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        {% include 'components/ui/_alert.html.twig' with { tone: 'error', message: message } only %}
                    {% endfor %}

                    <form method="post" class="toastit-stack">
                        {% include 'components/forms/_segmented_code_input.html.twig' with {
                            id: 'unlock-pin',
                            name: 'pin',
                            label: 'PIN',
                            length: 4,
                            mode: 'numeric',
                            autocomplete: 'off',
                            auto_submit: true
                        } only %}
                        <div class="buttons mb-0">
                            {% include 'components/ui/_button.html.twig' with {
                                variant: 'primary',
                                type: 'submit',
                                label: 'Deverrouiller'
                            } only %}
                        </div>
                    </form>
                    <form method="post" action="{{ path('app_pin_forgot') }}">
                        {% include 'components/ui/_button.html.twig' with {
                            variant: 'notice',
                            type: 'submit',
                            label: "J'ai oublie mon PIN"
                        } only %}
                    </form>
                </div>
            {% endblock %}
        {% endembed %}
    </main>
{% endblock %}
